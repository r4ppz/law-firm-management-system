# Docker Compose
COMPOSE_FILE=docker-compose.prod.yml
COMPOSE_PROJECT_NAME=law-firm-management-system-production

# App Database URL
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# NextAuth secret — generate with: pnpx auth secret
AUTH_SECRET=
# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated email addresses granted developer access
DEVELOPER_EMAILS=

# S3-compatible storage (MinIO in Docker network)
# MinIO server-side encryption at rest (SSE-S3, single master key).
# MINIO_KMS_AUTO_ENCRYPTION=on encrypts every new object automatically.
# Generate a 32-byte key:  openssl rand -base64 32
# Format:  MINIO_KMS_SECRET_KEY=<key-name>:<base64-key>
# Add the real value to .env.prod (gitignored) — never commit the key.
# MINIO_KMS_SECRET_KEY=
# MINIO_KMS_AUTO_ENCRYPTION=on
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true
