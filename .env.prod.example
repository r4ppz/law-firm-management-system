# ════════════════════════════════════════════════════════════
# DOCKER COMPOSE (production)
# ════════════════════════════════════════════════════════════
COMPOSE_FILE=docker-compose.prod.yml
COMPOSE_PROJECT_NAME=law-firm-management-system-production

# ════════════════════════════════════════════════════════════
# MINIO (S3-compatible storage)
# ════════════════════════════════════════════════════════════
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO SSE-S3 encryption at rest (32-byte base64 key)
# Generate:  openssl rand -base64 32
# Add the real value to .env.prod (gitignored) — never commit the key.
# MINIO_KMS_SECRET_KEY=
# MINIO_KMS_AUTO_ENCRYPTION=on

# ════════════════════════════════════════════════════════════
# APPLICATION RUNTIME (consumed by Next.js / Prisma)
# ════════════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# ── Authentication ──
# AUTH_SECRET:  openssl rand -hex 32
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Developer Access ──
DEVELOPER_EMAILS=

# ── S3 Storage (MinIO in Docker network) ──
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true

# ── Email (Gmail SMTP) ──
# Generate an App Password:  https://myaccount.google.com/apppasswords
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-char-app-password
# EMAIL_FROM="Anino Law Firm <your-email@gmail.com>"
# EMAIL_SECURE=false
