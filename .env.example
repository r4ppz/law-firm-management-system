# ════════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════════
# Local Postgres via Docker:  docker compose up -d
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# ════════════════════════════════════════════════════════════
# AUTHENTICATION (NextAuth + Google OAuth)
# ════════════════════════════════════════════════════════════
# AUTH_SECRET:  openssl rand -hex 32
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ════════════════════════════════════════════════════════════
# DEVELOPER ACCESS
# ════════════════════════════════════════════════════════════
# Comma-separated emails granted dev-only features
DEVELOPER_EMAILS=

# ════════════════════════════════════════════════════════════
# OBJECT STORAGE (S3-compatible — MinIO via Docker)
# ════════════════════════════════════════════════════════════
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true

# ════════════════════════════════════════════════════════════
# EMAIL (SMTP — MailHog for local dev)
# ════════════════════════════════════════════════════════════
# Web UI:  http://localhost:8025
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=mailhog
EMAIL_PASS=mailhog
EMAIL_FROM=Anino Law Firm <test@localhost>
EMAIL_SECURE=false

# ════════════════════════════════════════════════════════════
# APPLICATION
# ════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_VERSION=0.0.0-dev
