# PostgreSQL connection string for Prisma ORM
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# For local development with Docker DB:
#   docker compose up -d
#   DATABASE_URL=postgresql://testing:testing@localhost:5432/testing
#
# For full production stack in Docker:
#   docker compose -f docker-compose.prod.yml up
#   (DATABASE_URL is set automatically inside containers)
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# NextAuth secret — generate with: pnpx auth secret
AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated email addresses granted developer access
DEVELOPER_EMAILS=

# S3-compatible object storage
# For local dev with MinIO (docker compose up -d):
#   S3_ENDPOINT=http://localhost:9000
#   S3_ACCESS_KEY=minioadmin
#   S3_SECRET_KEY=minioadmin
#   S3_FORCE_PATH_STYLE=true
#
# For AWS S3:
#   S3_ENDPOINT=https://s3.<region>.amazonaws.com
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true

# Build-time application version — auto-set by CI release workflow; falls back to 0.0.0-dev locally
NEXT_PUBLIC_APP_VERSION=0.0.0-dev
