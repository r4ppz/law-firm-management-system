{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":separateMajorMinor", ":combinePatchMinorUpdates"],
  "schedule": ["before 9am on monday"],
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchPackageNames": ["@types/node"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["^@types/"],
      "automerge": true,
      "minimumReleaseAge": "0"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  }
}
