# ════════════════════════════════════════════════════════════
# DOCKER COMPOSE (dev)
# ════════════════════════════════════════════════════════════
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=law-firm-management-system-development

# ════════════════════════════════════════════════════════════
# POSTGRESQL
# ════════════════════════════════════════════════════════════
POSTGRES_DB=testing
POSTGRES_USER=testing
POSTGRES_PASSWORD=testing

# ════════════════════════════════════════════════════════════
# MINIO (S3-compatible storage)
# ════════════════════════════════════════════════════════════
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO SSE-S3 encryption at rest (32-byte base64 key)
# Generate:  openssl rand -base64 32
# Add the real value to .env.dev (gitignored) — never commit the key.
# MINIO_KMS_SECRET_KEY=
# MINIO_KMS_AUTO_ENCRYPTION=on

# ════════════════════════════════════════════════════════════
# APPLICATION RUNTIME (consumed by Next.js / Prisma)
# ════════════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# ── Authentication ──
# AUTH_SECRET:  openssl rand -hex 32
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Developer Access ──
DEVELOPER_EMAILS=

# ── S3 Storage ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true

# ── Email (MailHog) ──
EMAIL_FROM="Anino Law Firm <test@localhost>"
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=mailhog
EMAIL_PASS=mailhog

# ── Application URL ──
APP_ORIGIN=http://localhost:3000
