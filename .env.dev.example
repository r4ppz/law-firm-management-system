# Docker Compose
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=law-firm-management-system-development

# PostgreSQL
POSTGRES_DB=testing
POSTGRES_USER=testing
POSTGRES_PASSWORD=testing

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# App Database URL
DATABASE_URL=postgresql://testing:testing@localhost:5432/testing

# NextAuth secret — generate with: pnpx auth secret
AUTH_SECRET=
# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated email addresses granted developer access
DEVELOPER_EMAILS=

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=law-firm-files
S3_FORCE_PATH_STYLE=true
