{
  "name": "law-firm-management-system",
  "version": "2026.07.20.2",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm prisma:generate && next build",
    "start": "next start",
    "prepare": "husky || true && prisma generate",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --cache && pnpm prisma format",
    "validate": "pnpm format && pnpm lint && tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:browser": "vitest run --project storybook",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@internationalized/date": "^3.12.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-aria-components": "^1.19.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write --cache",
      "eslint --fix --cache"
    ],
    "*.{json,css,md}": [
      "prettier --write --cache"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@fontsource/roboto": "^5.2.10",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-storybook": "^10.4.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "storybook": "^10.4.6",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
