{
  "name": "law-firm-management-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm prisma:generate && next build",
    "start": "next start",
    "prepare": "husky || true && prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" && pnpm prisma format",
    "validate": "pnpm format && pnpm lint && tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:browser": "vitest run --project storybook",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-aria-components": "^1.18.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/nextjs-vite": "^10.4.3",
    "@types/node": "^20.19.42",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-storybook": "^10.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "storybook": "^10.4.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
